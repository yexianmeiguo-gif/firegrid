// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表 - 基础信息
model User {
  id            String    @id @default(uuid())
  openId        String    @unique @map("open_id") // 微信OpenID
  phone         String?   @unique // 手机号
  nickname      String?   // 昵称
  avatar        String?   // 头像URL
  role          UserRole  @default(GUEST) // 角色
  status        UserStatus @default(ACTIVE) // 状态
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  // 关联
  firefighterProfile  FirefighterProfile?
  supplierProfile     SupplierProfile?
  reviews             Review[]
  aiPromptLogs        AIPromptLog[]
  favorites           Favorite[]
  
  @@map("users")
}

// 消防核心用户档案 (C/G端)
model FirefighterProfile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 职业信息
  rank            String?   // 职级
  department      String?   // 部门
  region          String?   // 所在地区
  certification   String?   // 认证信息
  
  // 偏好设置
  favoriteCategories String[] @default([]) @map("favorite_categories") // 关注的器材类目
  trainingHours   Int       @default(0) @map("training_hours") // 培训时长
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@map("firefighter_profiles")
}

// 供应商档案 (B端)
model SupplierProfile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 企业信息
  companyName     String    @map("company_name")
  businessLicense String?   @map("business_license") // 营业执照
  mainCategories  String[]  @default([]) @map("main_categories") // 主营类目
  contactPhone    String?   @map("contact_phone")
  contactEmail    String?   @map("contact_email")
  address         String?   // 地址
  
  // 订阅等级
  subscription    SubscriptionTier @default(FREE) @map("subscription_tier")
  
  // 产品关联
  products        Equipment[]
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@map("supplier_profiles")
}

// 装备表
model Equipment {
  id              String    @id @default(uuid())
  name            String    // 装备名称
  manufacturer    String    // 制造商
  category        String    // 类别
  subCategory     String?   @map("sub_category") // 子类别
  standards       String[]  // 合规标准
  
  // 新增AI相关字段
  applications    String[]  @default([]) // 适用场景
  scenarioTags    String[]  @default([]) @map("scenario_tags") // 实战标签

  // 结构化参数 (JSONB)
  parameters      Json      @default("{}") @map("parameters")
  
  // 描述和图片
  description     String?   @db.Text
  images          String[]  @default([])
  
  // 供应商关联
  supplierId      String    @map("supplier_id")
  supplier        SupplierProfile @relation(fields: [supplierId], references: [id])
  
  // 关联
  reviews         Review[]
  favorites       Favorite[]
  caseStudies     CaseStudy[] // 关联实战案例
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@map("equipment")
}

// 新增：装备实战案例表
model CaseStudy {
  id            String    @id @default(uuid())
  title         String    // 案例标题
  equipmentId   String    @map("equipment_id")
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  // 案例详情
  content       String    @db.Text
  images        String[]  @default([])
  videoUrl      String?   @map("video_url")
  
  // 信息来源
  author        String?   // 作者/单位
  publishDate   DateTime  @default(now()) @map("publish_date")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("case_studies")
}

// 评价表
model Review {
  id            String    @id @default(uuid())
  equipmentId   String    @map("equipment_id")
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating        Int       // 评分 1-5
  content       String?   @db.Text
  
  createdAt     DateTime  @default(now()) @map("created_at")
  
  @@map("reviews")
}

// 收藏表
model Favorite {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  equipmentId   String    @map("equipment_id")
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now()) @map("created_at")
  
  @@unique([userId, equipmentId])
  @@map("favorites")
}

// 招投标信息表
model Tender {
  id              String    @id @default(uuid())
  title           String    // 标题
  tenderId        String?   @unique @map("tender_id") // 招标公告ID
  purchaser       String    // 采购单位
  amount          Decimal?  @db.Decimal(15, 2) // 金额
  status          TenderStatus @default(OPEN) // 状态
  publishDate     DateTime  @map("publish_date") // 发布时间
  deadline        DateTime? // 截止日期
  region          String?   // 地区
  category        String?   // 类目
  url             String?   // 原文链接
  content         String?   @db.Text // 内容摘要
  
  // 中标信息
  winner          String?   // 中标企业
  winAmount       Decimal?  @map("win_amount") @db.Decimal(15, 2) // 中标金额
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@map("tenders")
}

// AI生成记录表
model AIPromptLog {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 输入参数
  category      String    // 装备类别
  budget        String?   // 预算
  requirements  String?   @db.Text // 核心参数要求
  
  // 输出结果
  output        String    @db.Text // 生成的文档
  
  // 模型信息
  model         String    @default("gpt-4") // 使用的模型
  tokens        Int?      // 消耗的token数
  
  createdAt     DateTime  @default(now()) @map("created_at")
  
  @@map("ai_prompt_logs")
}

// 资讯文章表
model Article {
  id            String    @id @default(uuid())
  title         String
  summary       String?   // 摘要
  content       String?   @db.Text // 内容（可为空，外链）
  coverImage    String?   @map("cover_image") // 封面图
  author        String?   // 作者
  source        String?   // 来源
  sourceUrl     String?   @map("source_url") // 原文链接
  category      String    // 分类
  tags          String[]  @default([])
  
  // 类型: article(文章) | video(视频) | case(案例)
  type          ContentType @default(ARTICLE)
  
  // 统计数据
  viewCount     Int       @default(0) @map("view_count")
  likeCount     Int       @default(0) @map("like_count")
  
  isPublished   Boolean   @default(true) @map("is_published")
  publishAt     DateTime  @default(now()) @map("publish_at")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("articles")
}

// 枚举定义
enum UserRole {
  GUEST       // 游客
  FIREFIGHTER // 消防核心用户
  SUPPLIER    // 供应商
  ADMIN       // 管理员
}

enum UserStatus {
  ACTIVE    // 活跃
  INACTIVE  // 未激活
  SUSPENDED // 停用
}

enum SubscriptionTier {
  FREE      // 免费版
  PRO       // 专业版
  ENTERPRISE // 企业版
}

enum TenderStatus {
  OPEN      // 招标中
  CLOSED    // 已截止
  AWARDED   // 已中标
  CANCELLED // 已流标
}

enum ContentType {
  ARTICLE // 文章
  VIDEO   // 视频
  CASE    // 案例
}// 供需撮合中心数据模型
// 添加到 Prisma Schema

// 采购需求表（消防队/政府发布）
model ProcurementDemand {
  id            String    @id @default(uuid())
  title         String    // 需求标题
  description   String?   @db.Text // 详细描述
  
  // 发布方信息
  publisherId   String    @map("publisher_id")
  publisherType UserRole  @map("publisher_type") // FIREFIGHTER 或 ADMIN
  department    String?   // 部门/单位名称
  region        String    // 所在地区（省市区）
  contactName   String?   @map("contact_name")
  contactPhone  String?   @map("contact_phone")
  
  // 需求详情
  category      String    // 装备类别
  subCategory   String?   @map("sub_category")
  budgetMin     Decimal?  @map("budget_min") @db.Decimal(15, 2) // 预算下限
  budgetMax     Decimal?  @map("budget_max") @db.Decimal(15, 2) // 预算上限
  quantity      Int?      // 采购数量
  requirements  Json?     // 技术参数要求（JSON格式）
  
  // 时间要求
  deadline      DateTime? // 期望交付日期
  validUntil    DateTime  @map("valid_until") // 需求有效期
  
  // 状态
  status        DemandStatus @default(OPEN) // OPEN/CLOSED/MATCHED/COMPLETED
  
  // 匹配记录
  matches       DemandMatch[]
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("procurement_demands")
  @@index([status, category])
  @@index([region])
  @@index([validUntil])
}

// 供应发布表（厂商/贸易商发布）
model SupplyOffer {
  id            String    @id @default(uuid())
  title         String    // 供应标题
  description   String?   @db.Text // 详细描述
  
  // 发布方信息
  supplierId    String    @map("supplier_id")
  companyName   String    @map("company_name")
  region        String    // 所在地区
  contactName   String?   @map("contact_name")
  contactPhone  String?   @map("contact_phone")
  
  // 产品信息
  category      String    // 装备类别
  subCategory   String?   @map("sub_category")
  brand         String?   // 品牌
  model         String?   // 型号
  price         Decimal?  @db.Decimal(15, 2) // 单价
  quantity      Int?      // 可供应数量
  specifications Json?    // 技术参数
  
  // 资质认证
  certificates  String[]  // 认证证书（3C、消防认证等）
  
  // 库存状态
  stockStatus   StockStatus @map("stock_status") @default(IN_STOCK) // IN_STOCK/PRE_ORDER/CUSTOM
  deliveryDays  Int?        @map("delivery_days") // 交货周期（天）
  
  // 状态
  status        OfferStatus @default(ACTIVE) // ACTIVE/SOLD_OUT/EXPIRED
  validUntil    DateTime    @map("valid_until")
  
  // 匹配记录
  matches       DemandMatch[]
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@map("supply_offers")
  @@index([status, category])
  @@index([region])
  @@index([validUntil])
}

// 供需匹配记录表
model DemandMatch {
  id              String      @id @default(uuid())
  
  demandId        String      @map("demand_id")
  demand          ProcurementDemand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  
  offerId         String      @map("offer_id")
  offer           SupplyOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  
  // 匹配分数（算法计算）
  matchScore      Float       @map("match_score") // 0-100
  matchReasons    Json?       @map("match_reasons") // 匹配原因（如：["地域匹配", "预算匹配"]）
  
  // 双方意向
  demandInterest  InterestStatus @map("demand_interest") @default(PENDING) // PENDING/INTERESTED/NOT_INTERESTED
  offerInterest   InterestStatus @map("offer_interest") @default(PENDING)
  
  // 撮合状态
  status          MatchStatus @default(PENDING) // PENDING/CONTACTED/NEGOTIATING/COMPLETED/CANCELLED
  
  // 沟通记录
  contactHistory  Json?       @map("contact_history") // 联系记录
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  @@unique([demandId, offerId])
  @@map("demand_matches")
  @@index([status])
  @@index([matchScore])
}

// 枚举定义
enum DemandStatus {
  OPEN      // 开放中
  MATCHED   // 已匹配
  NEGOTIATING // 洽谈中
  COMPLETED // 已完成
  CANCELLED // 已取消
  EXPIRED   // 已过期
}

enum OfferStatus {
  ACTIVE    // 在售
  SOLD_OUT  // 售罄
  EXPIRED   // 已过期
  WITHDRAWN // 已下架
}

enum StockStatus {
  IN_STOCK    // 现货
  PRE_ORDER   // 预订
  CUSTOM      // 定制
  LIMITED     // 限量
}

enum InterestStatus {
  PENDING          // 待反馈
  INTERESTED       // 有意向
  NOT_INTERESTED   // 无意向
  CONTACTED        // 已联系
}

enum MatchStatus {
  PENDING      // 待撮合
  CONTACTED    // 已联系
  NEGOTIATING  // 洽谈中
  COMPLETED    // 已完成
  CANCELLED    // 已取消
}