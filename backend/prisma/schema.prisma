generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  openId             String              @unique @map("open_id")
  phone              String?             @unique
  nickname           String?
  avatar             String?
  role               UserRole            @default(GUEST)
  status             UserStatus          @default(ACTIVE)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  aiPromptLogs       AIPromptLog[]
  favorites          Favorite[]
  firefighterProfile FirefighterProfile?
  inquiries          inquiries[]
  reviews            Review[]
  supplierProfile    SupplierProfile?

  @@map("users")
}

model FirefighterProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  rank               String?
  department         String?
  region             String?
  certification      String?
  favoriteCategories String[] @default([]) @map("favorite_categories")
  trainingHours      Int      @default(0) @map("training_hours")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("firefighter_profiles")
}

model SupplierProfile {
  id              String           @id @default(uuid())
  userId          String           @unique @map("user_id")
  companyName     String           @map("company_name")
  businessLicense String?          @map("business_license")
  mainCategories  String[]         @default([]) @map("main_categories")
  contactPhone    String?          @map("contact_phone")
  contactEmail    String?          @map("contact_email")
  address         String?
  subscription    SubscriptionTier @default(FREE) @map("subscription_tier")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  products        Equipment[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("supplier_profiles")
}

model Equipment {
  id                                                 String                @id @default(uuid())
  name                                               String
  manufacturer                                       String
  category                                           String
  subCategory                                        String?               @map("sub_category")
  standards                                          String[]
  applications                                       String[]              @default([])
  scenarioTags                                       String[]              @default([]) @map("scenario_tags")
  parameters                                         Json                  @default("{}") @map("parameters")
  description                                        String?
  images                                             String[]              @default([])
  supplierId                                         String?               @map("supplier_id")
  createdAt                                          DateTime              @default(now()) @map("created_at")
  updatedAt                                          DateTime              @updatedAt @map("updated_at")
  manufacturer_id                                    String?               @db.Uuid
  primary_supplier_id                                String?               @db.Uuid
  caseStudies                                        CaseStudy[]
  companies_equipment_manufacturer_idTocompanies     companies?            @relation("equipment_manufacturer_idTocompanies", fields: [manufacturer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies_equipment_primary_supplier_idTocompanies companies?            @relation("equipment_primary_supplier_idTocompanies", fields: [primary_supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier                                           SupplierProfile?      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  equipment_suppliers                                equipment_suppliers[]
  favorites                                          Favorite[]
  inquiries                                          inquiries[]
  reviews                                            Review[]

  @@index([manufacturer_id], map: "idx_equipment_manufacturer")
  @@index([primary_supplier_id], map: "idx_equipment_primary_supplier")
  @@map("equipment")
}

model CaseStudy {
  id          String    @id @default(uuid())
  title       String
  equipmentId String    @map("equipment_id")
  content     String
  images      String[]  @default([])
  videoUrl    String?   @map("video_url")
  author      String?
  publishDate DateTime  @default(now()) @map("publish_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("case_studies")
}

model Review {
  id          String    @id @default(uuid())
  equipmentId String    @map("equipment_id")
  userId      String    @map("user_id")
  rating      Int
  content     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Favorite {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  equipmentId String    @map("equipment_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, equipmentId])
  @@map("favorites")
}

model Tender {
  id          String       @id @default(uuid())
  title       String
  tenderId    String?      @unique @map("tender_id")
  purchaser   String
  amount      Decimal?     @db.Decimal(15, 2)
  status      TenderStatus @default(OPEN)
  publishDate DateTime     @map("publish_date")
  deadline    DateTime?
  region      String?
  category    String?
  url         String?
  content     String?
  winner      String?
  winAmount   Decimal?     @map("win_amount") @db.Decimal(15, 2)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("tenders")
}

model AIPromptLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  category     String
  budget       String?
  requirements String?
  output       String
  model        String   @default("gpt-4")
  tokens       Int?
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_prompt_logs")
}

model Article {
  id          String      @id @default(uuid())
  title       String
  summary     String?
  content     String?
  coverImage  String?     @map("cover_image")
  author      String?
  source      String?
  sourceUrl   String?     @map("source_url")
  category    String
  tags        String[]    @default([])
  type        ContentType @default(ARTICLE)
  viewCount   Int         @default(0) @map("view_count")
  likeCount   Int         @default(0) @map("like_count")
  isPublished Boolean     @default(true) @map("is_published")
  publishAt   DateTime    @default(now()) @map("publish_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("articles")
}

model ProcurementDemand {
  id            String        @id @default(uuid())
  title         String
  description   String?
  publisherId   String        @map("publisher_id")
  publisherType UserRole      @map("publisher_type")
  department    String?
  region        String
  contactName   String?       @map("contact_name")
  contactPhone  String?       @map("contact_phone")
  category      String
  subCategory   String?       @map("sub_category")
  budgetMin     Decimal?      @map("budget_min") @db.Decimal(15, 2)
  budgetMax     Decimal?      @map("budget_max") @db.Decimal(15, 2)
  quantity      Int?
  requirements  Json?
  deadline      DateTime?
  validUntil    DateTime      @map("valid_until")
  status        DemandStatus  @default(OPEN)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  matches       DemandMatch[]

  @@index([status, category])
  @@index([region])
  @@index([validUntil])
  @@map("procurement_demands")
}

model SupplyOffer {
  id             String        @id @default(uuid())
  title          String
  description    String?
  supplierId     String        @map("supplier_id")
  companyName    String        @map("company_name")
  region         String
  contactName    String?       @map("contact_name")
  contactPhone   String?       @map("contact_phone")
  category       String
  subCategory    String?       @map("sub_category")
  brand          String?
  model          String?
  price          Decimal?      @db.Decimal(15, 2)
  quantity       Int?
  specifications Json?
  certificates   String[]
  stockStatus    StockStatus   @default(IN_STOCK) @map("stock_status")
  deliveryDays   Int?          @map("delivery_days")
  status         OfferStatus   @default(ACTIVE)
  validUntil     DateTime      @map("valid_until")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  matches        DemandMatch[]

  @@index([status, category])
  @@index([region])
  @@index([validUntil])
  @@map("supply_offers")
}

model DemandMatch {
  id             String            @id @default(uuid())
  demandId       String            @map("demand_id")
  offerId        String            @map("offer_id")
  matchScore     Float             @map("match_score")
  matchReasons   Json?             @map("match_reasons")
  demandInterest InterestStatus    @default(PENDING) @map("demand_interest")
  offerInterest  InterestStatus    @default(PENDING) @map("offer_interest")
  status         MatchStatus       @default(PENDING)
  contactHistory Json?             @map("contact_history")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  demand         ProcurementDemand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  offer          SupplyOffer       @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([demandId, offerId])
  @@index([status])
  @@index([matchScore])
  @@map("demand_matches")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model companies {
  id                                                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                               String                @unique(map: "companies_name_unique")
  name_en                                            String?
  short_name                                         String?
  is_manufacturer                                    Boolean?              @default(false)
  is_supplier                                        Boolean?              @default(false)
  partnership_status                                 String?               @default("none") @db.VarChar(50)
  partnership_level                                  Int?                  @default(0)
  subscription_start_date                            DateTime?             @db.Date
  subscription_end_date                              DateTime?             @db.Date
  contact_phone                                      String?               @db.VarChar(200)
  contact_email                                      String?               @db.VarChar(200)
  website                                            String?               @db.VarChar(500)
  address                                            String?
  postcode                                           String?               @db.VarChar(20)
  contact_person                                     String?               @db.VarChar(200)
  exhibition_booth                                   String?
  exhibition_year                                    Int?
  source                                             String?               @db.VarChar(50)
  source_url                                         String?
  company_scale                                      String?               @db.VarChar(50)
  certification                                      String[]
  product_count                                      Int?                  @default(0)
  total_inquiries                                    Int?                  @default(0)
  is_verified                                        Boolean?              @default(false)
  is_active                                          Boolean?              @default(true)
  created_at                                         DateTime?             @default(now()) @db.Timestamp(6)
  updated_at                                         DateTime?             @default(now()) @db.Timestamp(6)
  equipment_equipment_manufacturer_idTocompanies     Equipment[]           @relation("equipment_manufacturer_idTocompanies")
  equipment_equipment_primary_supplier_idTocompanies Equipment[]           @relation("equipment_primary_supplier_idTocompanies")
  equipment_suppliers                                equipment_suppliers[]
  inquiries                                          inquiries[]

  @@index([is_manufacturer], map: "idx_companies_is_manufacturer")
  @@index([is_supplier], map: "idx_companies_is_supplier")
  @@index([name], map: "idx_companies_name")
  @@index([partnership_level(sort: Desc)], map: "idx_companies_partnership_level")
  @@index([partnership_status], map: "idx_companies_partnership_status")
  @@index([source], map: "idx_companies_source")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model equipment_suppliers {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  equipment_id          String
  supplier_id           String    @db.Uuid
  supplier_type         String?   @default("reseller") @db.VarChar(50)
  price_min             Decimal?  @db.Decimal(12, 2)
  price_max             Decimal?  @db.Decimal(12, 2)
  price_unit            String?   @db.VarChar(50)
  is_available          Boolean?  @default(true)
  lead_time_days        Int?
  min_order_quantity    Int?      @default(1)
  priority              Int?      @default(0)
  recommendation_reason String?
  inquiry_count         Int?      @default(0)
  view_count            Int?      @default(0)
  created_at            DateTime? @default(now()) @db.Timestamp(6)
  updated_at            DateTime? @default(now()) @db.Timestamp(6)
  equipment             Equipment @relation(fields: [equipment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  companies             companies @relation(fields: [supplier_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([equipment_id, supplier_id], map: "equipment_suppliers_unique")
  @@index([is_available], map: "idx_equipment_suppliers_available")
  @@index([equipment_id], map: "idx_equipment_suppliers_equipment")
  @@index([priority(sort: Desc)], map: "idx_equipment_suppliers_priority")
  @@index([supplier_id], map: "idx_equipment_suppliers_supplier")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model exhibition_suppliers {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_name   String    @unique(map: "exhibition_suppliers_company_name_unique")
  booth          String?
  address        String?
  postcode       String?   @db.VarChar(20)
  phone          String?   @db.VarChar(200)
  fax            String?   @db.VarChar(100)
  email          String?   @db.VarChar(200)
  website        String?   @db.VarChar(500)
  contact_person String?   @db.VarChar(200)
  products       String?
  source         String?   @default("FIRE_2025") @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@index([booth], map: "idx_exhibition_suppliers_booth")
  @@index([company_name], map: "idx_exhibition_suppliers_company_name")
  @@index([email], map: "idx_exhibition_suppliers_email")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model inquiries {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String
  equipment_id      String
  supplier_id       String?    @db.Uuid
  quantity          Int?
  budget_min        Decimal?   @db.Decimal(12, 2)
  budget_max        Decimal?   @db.Decimal(12, 2)
  requirements      String?
  urgency           String?    @db.VarChar(50)
  status            String?    @default("pending") @db.VarChar(50)
  supplier_response String?
  quoted_price      Decimal?   @db.Decimal(12, 2)
  response_time     DateTime?  @db.Timestamp(6)
  created_at        DateTime?  @default(now()) @db.Timestamp(6)
  updated_at        DateTime?  @default(now()) @db.Timestamp(6)
  equipment         Equipment  @relation(fields: [equipment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies         companies? @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             User       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([equipment_id], map: "idx_inquiries_equipment")
  @@index([status], map: "idx_inquiries_status")
  @@index([supplier_id], map: "idx_inquiries_supplier")
  @@index([user_id], map: "idx_inquiries_user")
}

enum UserRole {
  GUEST
  FIREFIGHTER
  SUPPLIER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum TenderStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum ContentType {
  ARTICLE
  VIDEO
  CASE
}

enum DemandStatus {
  OPEN
  MATCHED
  NEGOTIATING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum OfferStatus {
  ACTIVE
  SOLD_OUT
  EXPIRED
  WITHDRAWN
}

enum StockStatus {
  IN_STOCK
  PRE_ORDER
  CUSTOM
  LIMITED
}

enum InterestStatus {
  PENDING
  INTERESTED
  NOT_INTERESTED
  CONTACTED
}

enum MatchStatus {
  PENDING
  CONTACTED
  NEGOTIATING
  COMPLETED
  CANCELLED
}
