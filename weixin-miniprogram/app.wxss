page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
  border-radius: 40rpx;
  border: none;
}

.text-primary { color: #ee5a24; }
.text-secondary { color: #666; }
.text-muted { color: #999; font-size: 24rpx; }

.flex { display: flex; }
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}