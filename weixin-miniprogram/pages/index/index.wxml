<!--pages/index/index.wxml-->
<view class="container page-enter">
  <!-- 顶部轮播Banner -->
  <view class="banner-wrapper">
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="4000" circular="true">
      <swiper-item>
        <view class="banner-item" style="background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);">
          <view class="banner-content">
            <text class="banner-title">🔥 FireGrid</text>
            <text class="banner-subtitle">消防装备信息化服务平台</text>
            <text class="banner-desc">连接消防队伍与装备供应商</text>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-item" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
          <view class="banner-content">
            <text class="banner-title">🤖 AI智能助手</text>
            <text class="banner-subtitle">一键生成专业招标文件</text>
            <text class="banner-desc">节省90%文档编写时间</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 快捷统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-number">{{stats.equipments || 6}}</text>
      <text class="stat-label">装备型号</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.tenders || 5}}</text>
      <text class="stat-label">招标项目</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{stats.suppliers || 4}}</text>
      <text class="stat-label">合作供应商</text>
    </view>
  </view>

  <!-- 功能入口 - 玻璃拟态效果 -->
  <view class="feature-section">
    <view class="section-title">核心功能</view>
    <view class="feature-grid">
      <view class="feature-card btn-active" bindtap="goToPage" data-url="/pages/equipment/equipment" style="animation-delay: 0.1s;">
        <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);">
          <text class="feature-icon">🧯</text>
        </view>
        <view class="feature-info">
          <text class="feature-name">装备库</text>
          <text class="feature-desc">浏览消防装备</text>
        </view>
        <text class="feature-arrow">></text>
      </view>

      <view class="feature-card btn-active" bindtap="goToPage" data-url="/pages/vehicles/vehicles" style="animation-delay: 0.15s;">
        <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #ff9f43 0%, #ff7b25 100%);">
          <text class="feature-icon">🚒</text>
        </view>
        <view class="feature-info">
          <text class="feature-name">消防车辆</text>
          <text class="feature-desc">专业车辆库</text>
        </view>
        <text class="feature-arrow">></text>
      </view>

      <view class="feature-card btn-active" bindtap="goToPage" data-url="/pages/tender/tender" style="animation-delay: 0.2s;">
        <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #4ecdc4 0%, #44a3aa 100%);">
          <text class="feature-icon">📋</text>
        </view>
        <view class="feature-info">
          <text class="feature-name">招标信息</text>
          <text class="feature-desc">全国招标商机</text>
        </view>
        <text class="feature-arrow">></text>
      </view>

      <view class="feature-card btn-active" bindtap="goToPage" data-url="/pages/ai/ai" style="animation-delay: 0.3s;">
        <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #a55eea 0%, #8b4fbf 100%);">
          <text class="feature-icon">🤖</text>
        </view>
        <view class="feature-info">
          <text class="feature-name">AI助手</text>
          <text class="feature-desc">智能生成标书</text>
        </view>
        <text class="feature-arrow">></text>
      </view>

      <view class="feature-card btn-active" bindtap="goToPage" data-url="/pages/article/article" style="animation-delay: 0.4s;">
        <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #26de81 0%, #20bf6b 100%);">
          <text class="feature-icon">📚</text>
        </view>
        <view class="feature-info">
          <text class="feature-name">专业资讯</text>
          <text class="feature-desc">行业知识库</text>
        </view>
        <text class="feature-arrow">></text>
      </view>
    </view>
  </view>

  <!-- AI特色卡片 -->
  <view class="ai-highlight-card btn-active hover-shadow" bindtap="goToPage" data-url="/pages/ai/ai">
    <view class="ai-badge">HOT</view>
    <view class="ai-content">
      <view class="ai-icon">🤖</view>
      <view class="ai-text">
        <text class="ai-title">AI招标文件生成器</text>
        <text class="ai-desc">输入装备需求，3秒生成专业招标文件</text>
      </view>
    </view>
    <view class="ai-action">
      <text class="ai-btn">立即体验</text>
      <view class="ai-arrow">→</view>
    </view>
  </view>

  <!-- 最新招标 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="section-icon">📋</view>
        <text class="section-title">最新招标</text>
      </view>
      <view class="more-btn btn-active" bindtap="goToPage" data-url="/pages/tender/tender">
        <text>查看更多</text>
        <text class="more-arrow">></text>
      </view>
    </view>
    
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-wrapper">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{!loading && tenders.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无招标信息</text>
    </view>
    
    <!-- 招标列表 -->
    <view wx:for="{{tenders}}" wx:key="id" class="tender-card btn-active hover-shadow" style="animation-delay: {{index * 0.1}}s;">
      <view class="tender-header">
        <view class="tender-status {{item.status || 'OPEN'}}">{{item.status === 'OPEN' ? '招标中' : item.status === 'AWARDED' ? '已中标' : '已截止'}}</view>
        <text class="tender-date">{{item.date}}</text>
      </view>
      
      <view class="tender-title">{{item.title}}</view>
      
      <view class="tender-meta">
        <view class="meta-item">
          <text class="meta-icon">📍</text>
          <text class="meta-text">{{item.region}}</text>
        </view>
        
        <view class="meta-item amount">
          <text class="meta-icon">💰</text>
          <text class="meta-text">{{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 热门装备 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="section-icon">🚒</view>
        <text class="section-title">热门装备</text>
      </view>
      <view class="more-btn btn-active" bindtap="goToPage" data-url="/pages/equipment/equipment">
        <text>查看更多</text>
        <text class="more-arrow">></text>
      </view>
    </view>
    
    <view class="equipment-scroll">
      <scroll-view scroll-x="true" class="equipment-list">
        <view wx:for="{{equipments}}" wx:key="id" class="equipment-card btn-active" style="animation-delay: {{index * 0.1}}s;">
          <view class="equipment-icon-wrapper">
            <text class="equipment-icon">{{item.icon}}</text>
          </view>
          <text class="equipment-name">{{item.name}}</text>
          <text class="equipment-brand">{{item.manufacturer}}</text>
          <view class="equipment-tag">查看详情</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="footer-space"></view>
</view>