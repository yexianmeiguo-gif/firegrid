/* pages/vehicles/vehicles.wxss */

.container {
  padding: 0 0 30rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 28rpx;
  margin-left: 20rpx;
  border-radius: 36rpx;
  padding: 0;
}

/* 分类标签 */
.category-tabs {
  white-space: nowrap;
  padding: 20rpx 10rpx;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.tab-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  margin: 0 10rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #ff6b6b;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 107, 0.3);
}

/* 车辆列表 */
.vehicle-list {
  padding: 20rpx 30rpx;
}

.vehicle-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding: 30rpx;
  margin-bottom: 30rpx;
  transition: transform 0.3s;
}

.vehicle-card:active {
  transform: scale(0.98);
}

.vehicle-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.vehicle-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.vehicle-info {
  flex: 1;
}

.vehicle-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.vehicle-manufacturer {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

.vehicle-image-placeholder {
  height: 320rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.placeholder-text {
  color: #bbb;
  font-size: 28rpx;
}

.vehicle-params {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.param-item {
  display: flex;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.param-item:last-child {
  margin-bottom: 0;
}

.param-label {
  color: #666;
  min-width: 160rpx;
}

.param-value {
  color: #333;
  flex: 1;
}

.vehicle-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.vehicle-category {
  font-size: 24rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  color: #999;
  padding: 30rpx 0;
  font-size: 24rpx;
}

.no-more {
  text-align: center;
  color: #999;
  padding: 30rpx 0;
  font-size: 24rpx;
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}