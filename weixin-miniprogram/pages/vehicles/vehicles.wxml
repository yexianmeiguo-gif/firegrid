<!--pages/vehicles/vehicles.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      type="text"
      placeholder="搜索车辆名称、制造商..."
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="doSearch"
    />
    <button class="search-btn" bindtap="doSearch">搜索</button>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="category-tabs">
    <view
      class="tab-item {{currentCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      data-category="{{item.id}}"
      bindtap="switchCategory"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 车辆列表 -->
  <view class="vehicle-list">
    <view
      class="vehicle-card"
      wx:for="{{vehicles}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="vehicle-header">
        <view class="vehicle-icon">
          {{item.category === 'water-tank' ? '🚒' :
            item.category === 'foam' ? '🧯' :
            item.category === 'ladder' ? '🚒' :
            item.category === 'rescue' ? '🚑' :
            item.category === 'special' ? '🚓' : '🚒'}}
        </view>
        <view class="vehicle-info">
          <text class="vehicle-name">{{item.name}}</text>
          <text class="vehicle-manufacturer">{{item.manufacturer}}</text>
        </view>
      </view>

      <view class="vehicle-image-placeholder">
        <text class="placeholder-text">车辆图片</text>
      </view>

      <view class="vehicle-params" wx:if="{{item.parameters}}">
        <view class="param-item" wx:for="{{item.parameters}}" wx:for-item="param" wx:for-index="key" wx:key="key">
          <text class="param-label">{{key}}:</text>
          <text class="param-value">{{param}}</text>
        </view>
      </view>

      <view class="vehicle-footer">
        <text class="vehicle-category">
          {{item.category === 'water-tank' ? '水罐消防车' :
            item.category === 'foam' ? '泡沫消防车' :
            item.category === 'ladder' ? '云梯消防车' :
            item.category === 'rescue' ? '抢险救援车' :
            item.category === 'special' ? '特种消防车' : '消防车'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    加载中...
  </view>

  <view class="no-more" wx:if="{{!hasMore && vehicles.length > 0}}">
    没有更多了
  </view>

  <view class="empty-state" wx:if="{{!loading && vehicles.length === 0}}">
    暂无车辆数据
  </view>
</view>