/* pages/equipment/detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading,
.empty {
  text-align: center;
  padding: 200rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 头部信息 */
.header {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  padding: 40rpx;
  display: flex;
  align-items: center;
}

.equipment-icon {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-right: 30rpx;
}

.header-info {
  flex: 1;
}

.equipment-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.equipment-manufacturer {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.equipment-standards {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.standard-tag {
  font-size: 22rpx;
  color: #ee5a24;
  background: rgba(255, 255, 255, 0.9);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 区块 */
.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 参数列表 */
.params-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.param-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.param-row:last-child {
  border-bottom: none;
}

.param-name {
  font-size: 28rpx;
  color: #666;
}

.param-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 描述 */
.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 供应商 */
.supplier-card {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
}

.supplier-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.supplier-contact,
.supplier-address {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

/* 底部按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.footer-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.footer-actions button::after {
  border: none;
}

.btn-favorite {
  background: #f5f5f5;
  color: #666;
}

.btn-contact {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
}