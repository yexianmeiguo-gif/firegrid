/* pages/equipment/equipment.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  padding: 20rpx;
  background: #fff;
  gap: 16rpx;
}

.search-bar input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  padding: 0;
  margin: 0;
}

.search-btn::after {
  border: none;
}

/* 分类标签 */
.category-tabs {
  background: #fff;
  padding: 0 20rpx 20rpx;
  white-space: nowrap;
}

.tab-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
}

/* 装备列表 */
.equipment-list {
  padding: 20rpx;
}

.equipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.equipment-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.equipment-icon {
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
}

.equipment-info {
  flex: 1;
}

.equipment-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.equipment-manufacturer {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 参数 */
.equipment-params {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 2rpx solid #f0f0f0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.param-item {
  display: flex;
  align-items: center;
}

.param-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.param-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 底部 */
.equipment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.equipment-category {
  font-size: 24rpx;
  color: #ee5a24;
  background: rgba(238, 90, 36, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.equipment-reviews {
  font-size: 24rpx;
  color: #999;
}

/* 状态 */
.loading-state,
.no-more,
.empty-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}