<!--pages/equipment/detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 装备详情 -->
  <block wx:if="{{!loading && equipment}}">
    <!-- 头部信息 -->
    <view class="header">
      <view class="equipment-icon">{{icon}}</view>
      <view class="header-info">
        <text class="equipment-name">{{equipment.name}}</text>
        <text class="equipment-manufacturer">{{equipment.manufacturer}}</text>
        <view class="equipment-standards">
          <text class="standard-tag" wx:for="{{equipment.standards}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 技术参数 -->
    <view class="section" wx:if="{{equipment.parameters}}">
      <view class="section-title">技术参数</view>
      <view class="params-list">
        <view class="param-row" wx:for="{{equipment.parameters}}" wx:for-item="value" wx:for-index="key" wx:key="key">
          <text class="param-name">{{key}}</text>
          <text class="param-value">{{value}}</text>
        </view>
      </view>
    </view>

    <!-- 产品描述 -->
    <view class="section" wx:if="{{equipment.description}}">
      <view class="section-title">产品描述</view>
      <view class="description">{{equipment.description}}</view>
    </view>

    <!-- 供应商信息 -->
    <view class="section" wx:if="{{equipment.supplier}}">
      <view class="section-title">供应商信息</view>
      <view class="supplier-card">
        <text class="supplier-name">{{equipment.supplier.companyName}}</text>
        <text class="supplier-contact" wx:if="{{equipment.supplier.contactPhone}}">📞 {{equipment.supplier.contactPhone}}</text>
        <text class="supplier-address" wx:if="{{equipment.supplier.address}}">📍 {{equipment.supplier.address}}</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="footer-actions">
      <button class="btn-favorite" bindtap="toggleFavorite">{{isFavorite ? '⭐ 已收藏' : '☆ 收藏'}}</button>
      <button class="btn-contact" bindtap="contactSupplier">联系供应商</button>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !equipment}}">
    装备信息不存在
  </view>
</view>