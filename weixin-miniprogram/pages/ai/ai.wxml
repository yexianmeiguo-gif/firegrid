<!--pages/ai/ai.wxml-->
<view class="container">
  <view class="header">
    <text class="title">🤖 AI招标文件生成器</text>
    <text class="subtitle">输入需求，AI自动生成专业招标文件</text>
  </view>

  <!-- 输入表单 -->
  <view class="form-card" wx:if="{{!result}}">
    <view class="form-item">
      <text class="label">* 采购装备类别</text>
      <input type="text" placeholder="例如：水罐消防车" bindinput="onCategoryInput" value="{{category}}"/>
    </view>

    <view class="form-item">
      <text class="label">* 预算金额</text>
      <input type="text" placeholder="例如：500万元" bindinput="onBudgetInput" value="{{budget}}"/>
    </view>

    <view class="form-item">
      <text class="label">核心参数要求</text>
      <textarea placeholder="请描述具体需求..." bindinput="onRequirementsInput" value="{{requirements}}" maxlength="500"/>
      <text class="counter">{{requirements.length}}/500</text>
    </view>

    <button class="submit-btn btn-primary" bindtap="generateDocument" disabled="{{loading}}">
      {{loading ? '生成中...' : '🚀 生成招标文件'}}
    </button>
  </view>

  <!-- 生成结果 -->
  <view class="result-card" wx:if="{{result}}">
    <view class="result-header">
      <text class="result-title">✅ 生成成功！</text>
      <text class="result-info">类别：{{category}} | 预算：{{budget}}</text>
    </view>
    
    <scroll-view scroll-y class="result-content">
      <text>{{result}}</text>
    </scroll-view>
    
    <view class="action-btns">
      <button bindtap="copyResult">📋 复制</button>
      <button bindtap="resetForm">🔄 重新生成</button>
    </view>
  </view>
</view>