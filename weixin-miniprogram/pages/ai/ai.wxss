/* pages/ai/ai.wxss */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

.form-card {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

input, textarea {
  width: 100%;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

textarea {
  height: 200rpx;
}

.counter {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.submit-btn {
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.result-card {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #26de81;
}

.result-info {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
}

.result-content {
  max-height: 800rpx;
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.result-content text {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.action-btns {
  display: flex;
  gap: 20rpx;
}

.action-btns button {
  flex: 1;
  font-size: 26rpx;
}