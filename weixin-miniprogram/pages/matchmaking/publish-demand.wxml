<!--pages/matchmaking/publish-demand.wxml-->
<view class="container">
  <view class="form-header">
    <text class="header-title">发布采购需求</text>
    <text class="header-subtitle">填写您的装备采购需求，系统将自动匹配合适的供应商</text>
  </view>

  <view class="form-content">
    <!-- 基本信息 -->
    <view class="form-section">
      <view class="section-label">基本信息</view>
      
      <view class="form-item">
        <text class="item-label required">需求标题</text>
        <input 
          class="item-input" 
          placeholder="例如：采购水罐消防车3辆"
          value="{{form.title}}"
          data-field="title"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label">详细描述</text>
        <textarea 
          class="item-textarea" 
          placeholder="请详细描述您的需求，包括技术参数、性能要求等"
          value="{{form.description}}"
          data-field="description"
          bindinput="onInput"
          maxlength="500"
        />
        <text class="char-count">{{form.description?.length || 0}}/500</text>
      </view>
    </view>

    <!-- 采购信息 -->
    <view class="form-section">
      <view class="section-label">采购信息</view>
      
      <view class="form-item">
        <text class="item-label required">装备类别</text>
        <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
          <view class="picker-item {{form.category ? '' : 'placeholder'}}">
            <text>{{selectedCategoryName || '请选择装备类别'}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
      
      <view class="form-row">
        <view class="form-item half">
          <text class="item-label">预算下限(万)</text>
          <input 
            class="item-input" 
            type="digit"
            placeholder="0"
            value="{{form.budgetMin}}"
            data-field="budgetMin"
            bindinput="onInput"
          />
        </view>
        
        <view class="form-item half">
          <text class="item-label">预算上限(万)</text>
          <input 
            class="item-input" 
            type="digit"
            placeholder="0"
            value="{{form.budgetMax}}"
            data-field="budgetMax"
            bindinput="onInput"
          />
        </view>
      </view>
      
      <view class="form-item">
        <text class="item-label">采购数量</text>
        <input 
          class="item-input" 
          type="number"
          placeholder="请输入采购数量"
          value="{{form.quantity}}"
          data-field="quantity"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label">期望交付日期</text>
        <picker mode="date" start="{{today}}" bindchange="onDateChange">
          <view class="picker-item {{form.deadline ? '' : 'placeholder'}}">
            <text>{{form.deadline || '请选择期望交付日期'}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 联系信息 -->
    <view class="form-section">
      <view class="section-label">联系信息</view>
      
      <view class="form-item">
        <text class="item-label required">所在单位</text>
        <input 
          class="item-input" 
          placeholder="例如：XX市消防救援支队"
          value="{{form.department}}"
          data-field="department"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label required">所在地区</text>
        <picker mode="region" bindchange="onRegionChange">
          <view class="picker-item {{form.region ? '' : 'placeholder'}}">
            <text>{{form.region || '请选择所在地区'}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="item-label">联系人</text>
        <input 
          class="item-input" 
          placeholder="请输入联系人姓名"
          value="{{form.contactName}}"
          data-field="contactName"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label">联系电话</text>
        <input 
          class="item-input" 
          type="number"
          placeholder="请输入联系电话"
          value="{{form.contactPhone}}"
          data-field="contactPhone"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 有效期 -->
    <view class="form-section">
      <view class="section-label">有效期设置</view>
      
      <view class="form-item">
        <text class="item-label">需求有效期</text>
        <view class="validity-options">
          <view 
            wx:for="{{validityOptions}}"
            wx:key="days"
            class="validity-item {{form.validDays === item.days ? 'active' : ''}}"
            data-days="{{item.days}}"
            bindtap="selectValidity"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitForm">
      {{loading ? '发布中...' : '发布需求'}}
    </button>
  </view>
</view>