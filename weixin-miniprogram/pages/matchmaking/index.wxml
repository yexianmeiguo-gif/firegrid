<!--pages/matchmaking/index.wxml-->
<view class="container">
  <!-- 顶部切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === 'demand' ? 'active' : ''}}"
      data-tab="demand"
      bindtap="switchTab"
    >
      <text class="tab-icon">📋</text>
      <text>采购需求</text>
    </view>
    <view 
      class="tab-item {{activeTab === 'supply' ? 'active' : ''}}"
      data-tab="supply"
      bindtap="switchTab"
    >
      <text class="tab-icon">📦</text>
      <text>供应信息</text>
    </view>
    <view 
      class="tab-item {{activeTab === 'match' ? 'active' : ''}}"
      data-tab="match"
      bindtap="switchTab"
    >
      <text class="tab-icon">🤝</text>
      <text>智能匹配</text>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item">
      <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
        <view class="picker">
          <text>{{selectedCategory || '全部类别'}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
    
    <view class="filter-item">
      <picker mode="region" bindchange="onRegionChange">
        <view class="picker">
          <text>{{selectedRegion || '全部地区'}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 采购需求列表 -->
  <view wx:if="{{activeTab === 'demand'}}">
    <view class="action-bar">
      <button class="publish-btn" bindtap="goPublishDemand">+ 发布需求</button>
    </view>
    
    <view class="list-container">
      <view wx:for="{{demands}}" wx:key="id" class="card demand-card">
        <view class="card-header">
          <view class="tag demand-tag">采购</view>
          <text class="time">{{item.createdAt}}</text>
        </view>
        
        <view class="card-title">{{item.title}}</view>
        
        <view class="card-content">
          <view class="info-row">
            <text class="label">预算：</text>
            <text class="value highlight">¥{{item.budgetMin}}-{{item.budgetMax}}万</text>
          </view>
          
          <view class="info-row">
            <text class="label">地区：</text>
            <text class="value">{{item.region}}</text>
          </view>
          
          <view class="info-row">
            <text class="label">单位：</text>
            <text class="value">{{item.department}}</text>
          </view>
        </view>
        
        <view class="card-footer">
          <text class="match-count">{{(item.matches && item.matches.length) || 0}} 个匹配</text>
          <button class="view-btn" data-id="{{item.id}}" bindtap="viewDemandDetail">查看匹配</button>
        </view>
      </view>
    </view>
    
    <view class="empty" wx:if="{{demands.length === 0}}">
      <text>暂无采购需求</text>
    </view>
  </view>

  <!-- 供应信息列表 -->
  <view wx:if="{{activeTab === 'supply'}}">
    <view class="action-bar">
      <button class="publish-btn" bindtap="goPublishSupply">+ 发布供应</button>
    </view>
    
    <view class="list-container">
      <view wx:for="{{offers}}" wx:key="id" class="card supply-card">
        <view class="card-header">
          <view class="tag supply-tag">供应</view>
          <text class="company">{{item.companyName}}</text>
        </view>
        
        <view class="card-title">{{item.title}}</view>
        
        <view class="card-content">
          <view class="info-row">
            <text class="label">价格：</text>
            <text class="value highlight">¥{{item.price}}万</text>
          </view>
          
          <view class="info-row">
            <text class="label">库存：</text>
            <text class="value">{{item.quantity}} 台</text>
          </view>
          
          <view class="info-row">
            <text class="label">地区：</text>
            <text class="value">{{item.region}}</text>
          </view>
        </view>
        
        <view class="card-footer">
          <text class="stock-status {{item.stockStatus}}">{{item.stockStatus === 'IN_STOCK' ? '现货' : '预订'}}</text>
          <button class="view-btn" data-id="{{item.id}}" bindtap="viewOfferDetail">查看详情</button>
        </view>
      </view>
    </view>
    
    <view class="empty" wx:if="{{offers.length === 0}}">
      <text>暂无供应信息</text>
    </view>
  </view>

  <!-- 智能匹配 -->
  <view wx:if="{{activeTab === 'match'}}">
    <view class="match-intro">
      <text class="intro-title">🤖 智能撮合系统</text>
      <text class="intro-desc">基于地域、预算、品类等多维度智能匹配</text>
    </view>
    
    <view class="my-items">
      <view class="section-title">我的发布</view>
      
      <view wx:for="{{myItems}}" wx:key="id" class="card my-card">
        <view class="my-card-header">
          <text class="my-type {{item.type}}">{{item.type === 'demand' ? '需求' : '供应'}}</text>
          <text class="my-title">{{item.title}}</text>
        </view>
        
        <view class="match-list" wx:if="{{item.matches && item.matches.length > 0}}">
          <view class="match-title">最佳匹配：</view>
          
          <view wx:for="{{item.matches}}" wx:for-item="match" wx:key="id" class="match-item">
            <view class="match-info">
              <text class="match-name">{{(match.offer && match.offer.title) || (match.demand && match.demand.title)}}</text>
              <view class="match-tags">
                <text wx:for="{{match.matchReasons}}" wx:for-item="reason" wx:key="*this" class="match-tag">{{reason}}</text>
              </view>
            </view>
            
            <view class="match-score">
              <text class="score-value">{{match.matchScore}}%</text>
              <text class="score-label">匹配度</text>
            </view>
          </view>
        </view>
        
        <view class="no-match" wx:if="{{!item.matches || item.matches.length === 0}}">
          <text>暂无匹配，系统正在为您寻找... </text>
        </view>
      </view>
      
      <view class="empty" wx:if="{{myItems.length === 0}}">
        <text>您还没有发布需求或供应</text>
        <button class="publish-btn" bindtap="goPublish">立即发布</button>
      </view>
    </view>
  </view>
</view>