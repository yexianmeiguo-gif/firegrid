<!--pages/matchmaking/publish-supply.wxml-->
<view class="container">
  <view class="form-header">
    <text class="header-title">发布供应信息</text>
    <text class="header-subtitle">填写您的装备供应信息，系统将自动匹配合适的采购需求</text>
  </view>

  <view class="form-content">
    <!-- 产品信息 -->
    <view class="form-section">
      <view class="section-label">产品信息</view>
      
      <view class="form-item">
        <text class="item-label required">供应标题</text>
        <input 
          class="item-input" 
          placeholder="例如：供应中联重科水罐消防车"
          value="{{form.title}}"
          data-field="title"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label">产品描述</text>
        <textarea 
          class="item-textarea" 
          placeholder="请详细描述产品特点、技术参数、优势等"
          value="{{form.description}}"
          data-field="description"
          bindinput="onInput"
          maxlength="500"
        />
        <text class="char-count">{{(form.description && form.description.length) || 0}}/500</text>
      </view>
    </view>

    <!-- 产品类别 -->
    <view class="form-section">
      <view class="section-label">产品类别</view>
      
      <view class="form-item">
        <text class="item-label required">装备类别</text>
        <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
          <view class="picker-item {{form.category ? '' : 'placeholder'}}">
            <text>{{selectedCategoryName || '请选择装备类别'}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="item-label">品牌</text>
        <input 
          class="item-input" 
          placeholder="例如：中联重科"
          value="{{form.brand}}"
          data-field="brand"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label">型号</text>
        <input 
          class="item-input" 
          placeholder="例如：ZLJ5320JXFJP18"
          value="{{form.model}}"
          data-field="model"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-row">
        <view class="form-item half">
          <text class="item-label required">单价(万)</text>
          <input 
            class="item-input" 
            type="digit"
            placeholder="0.00"
            value="{{form.price}}"
            data-field="price"
            bindinput="onInput"
          />
        </view>
        
        <view class="form-item half">
          <text class="item-label">可供应数量</text>
          <input 
            class="item-input" 
            type="number"
            placeholder="请输入数量"
            value="{{form.quantity}}"
            data-field="quantity"
            bindinput="onInput"
          />
        </view>
      </view>
      
      <view class="form-item">
        <text class="item-label">库存状态</text>
        <view class="stock-options">
          <view 
            wx:for="{{stockOptions}}"
            wx:key="value"
            class="stock-item {{form.stockStatus === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectStockStatus"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
      
      <view class="form-item" wx:if="{{form.stockStatus === 'PRE_ORDER' || form.stockStatus === 'CUSTOM'}}">
        <text class="item-label">交货周期(天)</text>
        <input 
          class="item-input" 
          type="number"
          placeholder="请输入交货天数"
          value="{{form.deliveryDays}}"
          data-field="deliveryDays"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 联系信息 -->
    <view class="form-section">
      <view class="section-label">联系信息</view>
      
      <view class="form-item">
        <text class="item-label required">所在地区</text>
        <picker mode="region" bindchange="onRegionChange">
          <view class="picker-item {{form.region ? '' : 'placeholder'}}">
            <text>{{form.region || '请选择所在地区'}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="item-label">联系人</text>
        <input 
          class="item-input" 
          placeholder="请输入联系人姓名"
          value="{{form.contactName}}"
          data-field="contactName"
          bindinput="onInput"
        />
      </view>
      
      <view class="form-item">
        <text class="item-label">联系电话</text>
        <input 
          class="item-input" 
          type="number"
          placeholder="请输入联系电话"
          value="{{form.contactPhone}}"
          data-field="contactPhone"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 有效期 -->
    <view class="form-section">
      <view class="section-label">有效期设置</view>
      
      <view class="form-item">
        <text class="item-label">供应有效期</text>
        <view class="validity-options">
          <view 
            wx:for="{{validityOptions}}"
            wx:key="days"
            class="validity-item {{form.validDays === item.days ? 'active' : ''}}"
            data-days="{{item.days}}"
            bindtap="selectValidity"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitForm">
      {{loading ? '发布中...' : '发布供应'}}
    </button>
  </view>
</view>