/* pages/matchmaking/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #ee5a24;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: linear-gradient(90deg, #ff6b6b, #ee5a24);
  border-radius: 2rpx;
}

.tab-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 20rpx;
  gap: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.filter-item {
  flex: 1;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.picker text {
  font-size: 26rpx;
  color: #333;
}

.arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}

/* 操作栏 */
.action-bar {
  padding: 20rpx;
  background: #fff;
}

.publish-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.publish-btn::after {
  border: none;
}

/* 列表容器 */
.list-container {
  padding: 20rpx;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.demand-tag {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.supply-tag {
  background: rgba(38, 222, 129, 0.1);
  color: #26de81;
}

.time, .company {
  font-size: 24rpx;
  color: #999;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.card-content {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  width: 100rpx;
}

.value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.value.highlight {
  color: #ee5a24;
  font-weight: bold;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.match-count {
  font-size: 24rpx;
  color: #667eea;
}

.stock-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.stock-status.IN_STOCK {
  background: rgba(38, 222, 129, 0.1);
  color: #26de81;
}

.stock-status.PRE_ORDER {
  background: rgba(238, 90, 36, 0.1);
  color: #ee5a24;
}

.view-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 24rpx;
  border: none;
}

/* 匹配介绍 */
.match-intro {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  text-align: center;
}

.intro-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.intro-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 我的发布 */
.my-items {
  padding: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.my-card {
  background: #fff;
}

.my-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.my-type {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.my-type.demand {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.my-type.supply {
  background: rgba(38, 222, 129, 0.1);
  color: #26de81;
}

.my-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.match-list {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.match-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.match-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.match-item:last-child {
  border-bottom: none;
}

.match-info {
  flex: 1;
}

.match-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.match-tag {
  font-size: 20rpx;
  color: #ee5a24;
  background: rgba(238, 90, 36, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.match-score {
  text-align: center;
  padding-left: 20rpx;
}

.score-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ee5a24;
}

.score-label {
  display: block;
  font-size: 20rpx;
  color: #999;
}

.no-match {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}